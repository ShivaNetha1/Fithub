# App
APP_NAME=Fithub
APP_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
# Create these in Supabase Dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Legacy Supabase key names. Leave empty unless your Supabase dashboard only shows legacy keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database
# Use Supabase Dashboard > Project Settings > Database > Connection string.
DATABASE_URL=
DIRECT_URL=

# Product defaults
CURRENCY_CODE=INR
EXPIRY_SOON_DAYS=7

# API protection
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
